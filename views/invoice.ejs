<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Invoice - <%= invoice.visitCode || invoice.visitID %></title>
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      padding: 18px;
      background: #ffffff;
      color: #111111;
      font-family: Arial, sans-serif;
      font-size: 12px;
      line-height: 1.35;
    }
    .toolbar {
      max-width: 860px;
      margin: 0 auto 12px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }
    .toolbar-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    .btn {
      display: inline-block;
      padding: 8px 12px;
      border: 1px solid #111111;
      background: #ffffff;
      color: #111111;
      text-decoration: none;
      font-size: 12px;
      cursor: pointer;
    }
    .sheet {
      max-width: 860px;
      margin: 0 auto;
      border: 1px solid #111111;
      background: #ffffff;
      padding: 16px 18px 18px;
    }
    .topline {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 24px;
      padding-bottom: 8px;
      margin-bottom: 10px;
      border-bottom: 1px solid #111111;
    }
    .title {
      font-size: 24px;
      font-weight: 700;
      margin-bottom: 4px;
    }
    .lab-name {
      font-size: 15px;
      font-weight: 700;
      margin-bottom: 2px;
    }
    .muted {
      color: #444444;
      font-size: 11px;
    }
    .meta {
      min-width: 280px;
      text-align: right;
    }
    .meta-row {
      margin-bottom: 3px;
    }
    .summary-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4px 24px;
      margin-bottom: 12px;
    }
    .summary-row {
      display: flex;
      gap: 6px;
    }
    .summary-row strong {
      min-width: 96px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
    }
    th, td {
      padding: 7px 8px;
      border: 1px solid #cfcfcf;
      text-align: left;
      vertical-align: top;
    }
    thead th {
      background: #5f5f5f;
      color: #ffffff;
      border-color: #5f5f5f;
      font-weight: 700;
    }
    .amount-cell {
      text-align: right;
      white-space: nowrap;
    }
    .totals {
      width: 320px;
      margin-left: auto;
      margin-top: 12px;
      border-collapse: collapse;
    }
    .totals td {
      border: none;
      padding: 5px 6px;
    }
    .totals td:first-child {
      font-weight: 700;
    }
    .totals td:last-child {
      text-align: right;
      font-weight: 700;
    }
    .paid-amount {
      color: #178a2f;
    }
    .discount-amount {
      color: #b45309;
    }
    .balance-box td {
      background: #ececec;
    }
    .words {
      margin-top: 8px;
      text-align: right;
      font-weight: 700;
    }
    @page {
      size: A4;
      margin: 10mm;
    }
    @media print {
      body { padding: 0; }
      .toolbar { display: none; }
      .sheet {
        max-width: none;
        border: 1px solid #111111;
      }
    }
  </style>
</head>
<body>
  <%
    const items = (invoice.selectedItems || []).map(function(item) {
      return {
        type: item.type || '',
        name: item.name || '',
        amount: Number(item.amount || 0)
      };
    });
    const totalInWords = (function(amount) {
      const ones = ['','One','Two','Three','Four','Five','Six','Seven','Eight','Nine','Ten','Eleven','Twelve','Thirteen','Fourteen','Fifteen','Sixteen','Seventeen','Eighteen','Nineteen'];
      const tens = ['','','Twenty','Thirty','Forty','Fifty','Sixty','Seventy','Eighty','Ninety'];
      function twoDigits(n) {
        if (n < 20) return ones[n];
        return tens[Math.floor(n / 10)] + (n % 10 ? ' ' + ones[n % 10] : '');
      }
      function threeDigits(n) {
        var out = '';
        if (n >= 100) {
          out += ones[Math.floor(n / 100)] + ' Hundred';
          n = n % 100;
          if (n) out += ' ';
        }
        if (n) out += twoDigits(n);
        return out.trim();
      }
      var value = Math.round(Number(amount || 0));
      if (!value) return 'Zero Only';
      var parts = [];
      var crore = Math.floor(value / 10000000); value %= 10000000;
      var lakh = Math.floor(value / 100000); value %= 100000;
      var thousand = Math.floor(value / 1000); value %= 1000;
      if (crore) parts.push(threeDigits(crore) + ' Crore');
      if (lakh) parts.push(threeDigits(lakh) + ' Lakh');
      if (thousand) parts.push(threeDigits(thousand) + ' Thousand');
      if (value) parts.push(threeDigits(value));
      return parts.join(' ') + ' Only';
    })(invoice.netAmount || 0);
  %>

  <div class="toolbar">
    <a href="/register" class="btn">Back</a>
    <div class="toolbar-actions">
      <a href="/invoice/<%= invoice.visitID %>?print=1" class="btn" onclick="return openInvoicePopup('/invoice/<%= invoice.visitID %>?print=1', true)">Open Print View</a>
      <button type="button" class="btn" onclick="window.print()">Print</button>
    </div>
  </div>

  <div class="sheet">
    <div class="topline">
      <div>
        <div class="title">Invoice</div>
        <div class="lab-name"><%= invoice.centerName || 'Laboratory Billing' %></div>
        <div class="muted"><%= invoice.centerAddress || 'Pathology / Laboratory Billing Copy' %></div>
      </div>
      <div class="meta">
        <div class="meta-row"><strong>Bill Id:</strong> <%= invoice.visitCode || '-' %></div>
        <div class="meta-row"><strong>Bill date:</strong> <%= formatInvoiceDate(invoice.registrationDateTime) || '-' %></div>
        <div class="meta-row"><strong>Payment Type:</strong> <%= invoice.paymentModeName || '-' %></div>
        <div class="meta-row"><strong>Referred By:</strong> <%= invoice.doctorName || invoice.referName || '-' %></div>
      </div>
    </div>

    <div class="summary-grid">
      <div class="summary-row"><strong>Name</strong><span>: <%= invoice.patientName || '-' %></span></div>
      <div class="summary-row"><strong>Patient ID</strong><span>: <%= invoice.patientID || '-' %></span></div>
      <div class="summary-row"><strong>Age/Gender</strong><span>: <%= invoice.age || '-' %> <%= invoice.ageType || '' %> / <%= invoice.gender || '-' %></span></div>
      <div class="summary-row"><strong>Mobile</strong><span>: <%= invoice.mobileNumber || '-' %></span></div>
    </div>

    <table>
      <thead>
        <tr>
          <th style="width:48px;">#</th>
          <th>Test Description</th>
          <th style="width:120px;" class="amount-cell">Amount</th>
        </tr>
      </thead>
      <tbody>
        <% if (items.length) { %>
          <% items.forEach(function(item, index) { %>
            <tr>
              <td><%= index + 1 %></td>
              <td><%= item.name %></td>
              <td class="amount-cell"><%= item.amount.toFixed(2) %></td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr>
            <td colspan="3">No itemized test details available.</td>
          </tr>
        <% } %>
      </tbody>
    </table>

    <table class="totals">
      <tr>
        <td>Total</td>
        <td><%= Number(invoice.grossAmount || 0).toFixed(2) %></td>
      </tr>
      <tr>
        <td>Discount</td>
        <td class="discount-amount"><%= Number(invoice.discountAmount || 0).toFixed(2) %></td>
      </tr>
      <tr>
        <td>Payment Made</td>
        <td class="paid-amount"><%= Number(invoice.paidAmount || 0).toFixed(2) %></td>
      </tr>
      <tr class="balance-box">
        <td>Balance Due</td>
        <td><%= Number(invoice.balanceAmount || 0).toFixed(2) %></td>
      </tr>
    </table>

    <div class="words">Total In Words: <%= totalInWords %></div>
  </div>

  <script src="/js/main.js"></script>
  <% if (autoPrint) { %>
  <script>
    window.addEventListener('load', function() {
      setTimeout(function() { window.print(); }, 200);
    });
  </script>
  <% } %>
</body>
</html>
