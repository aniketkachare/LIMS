<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Invoice - <%= invoice.visitCode || invoice.visitID %></title>
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      padding: 16px;
      background: #ffffff;
      color: #000000;
      font-family: Arial, sans-serif;
      font-size: 12px;
      line-height: 1.35;
    }
    .toolbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 12px;
    }
    .toolbar-actions {
      display: flex;
      gap: 8px;
    }
    .btn {
      display: inline-block;
      padding: 8px 12px;
      border: 1px solid #000000;
      background: #ffffff;
      color: #000000;
      text-decoration: none;
      font-size: 12px;
      cursor: pointer;
    }
    .invoice-sheet {
      width: 100%;
      max-width: 820px;
      margin: 0 auto;
      border: 1px solid #000000;
      padding: 18px 20px;
      background: #ffffff;
    }
    .header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 20px;
      border-bottom: 1px solid #000000;
      padding-bottom: 10px;
      margin-bottom: 12px;
    }
    .title {
      font-size: 20px;
      font-weight: 700;
      letter-spacing: 0.5px;
      margin-bottom: 4px;
    }
    .muted {
      font-size: 11px;
    }
    .meta {
      text-align: right;
      min-width: 220px;
    }
    .meta-row {
      margin-bottom: 4px;
    }
    .section {
      margin-bottom: 12px;
    }
    .section-title {
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      border-bottom: 1px solid #000000;
      padding-bottom: 4px;
      margin-bottom: 6px;
    }
    .patient-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4px 20px;
    }
    .patient-row {
      display: flex;
      gap: 8px;
    }
    .patient-row .label {
      min-width: 90px;
      font-weight: 700;
    }
    table {
      width: 100%;
      border-collapse: collapse;
    }
    th, td {
      border: 1px solid #000000;
      padding: 6px 8px;
      vertical-align: top;
      text-align: left;
    }
    th {
      font-weight: 700;
      background: #ffffff;
    }
    .summary {
      width: 320px;
      margin-left: auto;
      margin-top: 10px;
    }
    .summary td:first-child {
      font-weight: 700;
      width: 60%;
    }
    .summary td:last-child {
      text-align: right;
      width: 40%;
    }
    .status-line {
      margin-top: 10px;
      font-weight: 700;
    }
    @page {
      size: A4;
      margin: 10mm;
    }
    @media print {
      body {
        padding: 0;
      }
      .toolbar {
        display: none;
      }
      .invoice-sheet {
        max-width: none;
        border: 1px solid #000000;
        page-break-inside: avoid;
      }
    }
  </style>
</head>
<body>
  <div class="toolbar">
    <a href="/register" class="btn">Back</a>
    <div class="toolbar-actions">
      <a href="/invoice/<%= invoice.visitID %>?print=1" class="btn" target="_blank" rel="noopener noreferrer">Open Print View</a>
      <button type="button" class="btn" onclick="window.print()">Print</button>
    </div>
  </div>

  <div class="invoice-sheet">
    <div class="header">
      <div>
        <div class="title">INVOICE</div>
        <div class="muted">Patient Registration Invoice</div>
      </div>
      <div class="meta">
        <div class="meta-row"><strong>Visit Code:</strong> <%= invoice.visitCode || '-' %></div>
        <div class="meta-row"><strong>Visit ID:</strong> <%= invoice.visitID || '-' %></div>
        <div class="meta-row"><strong>Date:</strong> <%= formatInvoiceDate(invoice.registrationDateTime) || '-' %></div>
      </div>
    </div>

    <div class="section">
      <div class="section-title">Patient Details</div>
      <div class="patient-grid">
        <div class="patient-row"><span class="label">Patient ID</span><span>: <%= invoice.patientID || '-' %></span></div>
        <div class="patient-row"><span class="label">Patient Name</span><span>: <%= invoice.patientName || '-' %></span></div>
        <div class="patient-row"><span class="label">Gender</span><span>: <%= invoice.gender || '-' %></span></div>
        <div class="patient-row"><span class="label">Age</span><span>: <%= invoice.age || '-' %> <%= invoice.ageType || '' %></span></div>
        <div class="patient-row"><span class="label">Mobile</span><span>: <%= invoice.mobileNumber || '-' %></span></div>
        <div class="patient-row"><span class="label">Payment Mode</span><span>: <%= invoice.paymentModeName || '-' %></span></div>
      </div>
    </div>

    <div class="section">
      <div class="section-title">Items</div>
      <table>
        <thead>
          <tr>
            <th style="width: 90px;">Type</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <% if (invoice.selectedItems && invoice.selectedItems.length) { %>
            <% invoice.selectedItems.forEach(function(item) { %>
              <tr>
                <td><%= item.type %></td>
                <td><%= item.name %></td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr>
              <td colspan="2">No itemized test details available.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <table class="summary">
      <tr>
        <td>Gross Amount</td>
        <td><%= Number(invoice.grossAmount || 0).toFixed(2) %></td>
      </tr>
      <tr>
        <td>Visiting Charges</td>
        <td><%= Number(invoice.visitingCharges || 0).toFixed(2) %></td>
      </tr>
      <tr>
        <td>Discount</td>
        <td><%= Number(invoice.discountAmount || 0).toFixed(2) %></td>
      </tr>
      <tr>
        <td>Net Amount</td>
        <td><%= Number(invoice.netAmount || 0).toFixed(2) %></td>
      </tr>
      <tr>
        <td>Paid Amount</td>
        <td><%= Number(invoice.paidAmount || 0).toFixed(2) %></td>
      </tr>
      <tr>
        <td>Balance Amount</td>
        <td><%= Number(invoice.balanceAmount || 0).toFixed(2) %></td>
      </tr>
    </table>

    <div class="status-line">
      Status:
      <%= Number(invoice.balanceAmount || 0) > 0 ? 'Balance Due' : 'Paid' %>
    </div>
  </div>

  <% if (autoPrint) { %>
  <script>
    window.addEventListener('load', function() {
      setTimeout(function() { window.print(); }, 200);
    });
  </script>
  <% } %>
</body>
</html>
