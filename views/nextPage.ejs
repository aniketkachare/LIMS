<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Tests & Billing — LIMS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/main.css">
  <style>
    .patient-banner {
      background: var(--blue-50);
      border: 1px solid var(--blue-100);
      border-radius: var(--radius-lg);
      padding: 14px 20px;
      display: flex;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
      margin-bottom: 24px;
    }
    .pb-item { }
    .pb-label { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--gray-400); font-weight: 600; }
    .pb-value { font-size: 0.875rem; font-weight: 600; color: var(--gray-800); margin-top: 1px; }

    .receipt-box {
      background: var(--gray-50);
      border: 1px solid var(--gray-200);
      border-radius: var(--radius-md);
      padding: 16px 20px;
      margin-top: 16px;
    }
    .receipt-line {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 6px 0;
      font-size: 0.875rem;
      border-bottom: 1px solid var(--gray-100);
    }
    .receipt-line:last-child { border-bottom: none; }
    .receipt-line .rl-label { color: var(--gray-500); }
    .receipt-line .rl-value { font-weight: 600; font-family: var(--font-mono); color: var(--gray-800); }
    .receipt-line.total .rl-label { font-weight: 700; color: var(--gray-800); font-size: 0.95rem; }
    .receipt-line.total .rl-value { color: var(--blue-700); font-size: 1rem; }
    .receipt-line.balance .rl-value { color: var(--amber-600); }
  </style>
</head>
<body>
<div class="app-shell">

  <%- include('partials/sidebar', { activePage: 'register', user: user }) %>

  <div class="main-content">
    <header class="topbar">
      <button class="sidebar-toggle" id="sidebarToggle"><i class="fas fa-bars"></i></button>
      <div class="topbar-title">Tests &amp; Payment — Step 2</div>
      <div class="topbar-right">
        <div class="topbar-date"><i class="fas fa-calendar-alt"></i><span id="currentDate"></span></div>
      </div>
    </header>

    <main class="page-content">

      <!-- Step Wizard -->
      <div class="step-wizard">
        <div class="step done">
          <div class="step-circle"><i class="fas fa-check" style="font-size:0.7rem;"></i></div>
          <span class="step-label">Patient Info</span>
        </div>
        <div class="step-connector"></div>
        <div class="step active">
          <div class="step-circle">2</div>
          <span class="step-label">Tests &amp; Billing</span>
        </div>
        <div class="step-connector"></div>
        <div class="step">
          <div class="step-circle">3</div>
          <span class="step-label">Confirm</span>
        </div>
      </div>

      <!-- Patient summary banner -->
      <% if (registerData && registerData.patientName) { %>
      <div class="patient-banner">
        <div style="width:40px;height:40px;border-radius:50%;background:var(--blue-600);color:white;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1rem;flex-shrink:0;">
          <%= registerData.patientName ? registerData.patientName[0].toUpperCase() : 'P' %>
        </div>
        <div class="pb-item">
          <div class="pb-label">Patient</div>
          <div class="pb-value"><%= registerData.salutation || '' %> <%= registerData.patientName || '—' %></div>
        </div>
        <% if (registerData.gender) { %>
        <div class="pb-item">
          <div class="pb-label">Gender</div>
          <div class="pb-value"><%= registerData.gender %></div>
        </div>
        <% } %>
        <% if (registerData.age) { %>
        <div class="pb-item">
          <div class="pb-label">Age</div>
          <div class="pb-value"><%= registerData.age %> <%= registerData.ageType || 'Years' %></div>
        </div>
        <% } %>
        <% if (registerData.phone) { %>
        <div class="pb-item">
          <div class="pb-label">Mobile</div>
          <div class="pb-value"><%= registerData.countryCode || '' %> <%= registerData.phone %></div>
        </div>
        <% } %>
      </div>
      <% } %>

      <form action="/submit" method="POST" enctype="multipart/form-data" id="finalForm">
        <input type="hidden" name="paymentModeName" id="paymentModeName" />

        <!-- Payment -->
        <div class="card mb-20">
          <div class="card-header">
            <h3 class="card-title">
              <i class="fas fa-credit-card" style="color:#16a34a;margin-right:6px;"></i>Payment Details
            </h3>
          </div>
          <div class="card-body">
            <div class="form-grid form-grid-3">

              <div class="form-group">
                <label class="form-label">Payment Mode <span class="required">*</span></label>
                <select name="paymentMode" class="form-control" required>
                  <option value="">Select payment mode</option>
                  <% if (paymentModes && paymentModes.length) { %>
                    <% paymentModes.forEach(function(pm) { %>
                    <option value="<%= pm.PayModeID %>"><%= pm.PaymentMode %></option>
                    <% }); %>
                  <% } %>
                </select>
              </div>

              <div class="form-group">
                <label class="form-label">Gross Amount (₹)</label>
                <input type="number" name="grossAmount" id="grossAmount"
                  class="form-control" step="0.01" min="0" value="0" oninput="calcAmounts()" />
              </div>

              <div class="form-group">
                <label class="form-label">Visiting Charges (₹)</label>
                <input type="number" name="visitingCharges" id="visitingCharges"
                  class="form-control" step="0.01" min="0" value="0" oninput="calcAmounts()" />
              </div>

              <div class="form-group">
                <label class="form-label">Discount (₹)</label>
                <input type="number" name="discountAmount" id="discountAmount"
                  class="form-control" step="0.01" min="0" value="0" oninput="calcAmounts()" />
              </div>

              <div class="form-group">
                <label class="form-label">Paid Amount (₹)</label>
                <input type="number" name="paidAmount" id="paidAmount"
                  class="form-control" step="0.01" min="0" value="0" oninput="calcAmounts()" />
              </div>

              <div class="form-group">
                <label class="form-label">Balance Amount</label>
                <input type="number" name="balanceAmount" id="balanceAmount"
                  class="form-control" readonly value="0"
                  style="background:var(--gray-50);font-weight:700;color:var(--amber-600);" />
              </div>

            </div>

            <!-- Receipt summary -->
            <div class="receipt-box">
              <div class="receipt-line">
                <span class="rl-label">Gross + Visiting Charges</span>
                <span class="rl-value" id="dispTotal">₹ 0.00</span>
              </div>
              <div class="receipt-line">
                <span class="rl-label">Discount</span>
                <span class="rl-value" id="dispDiscount" style="color:var(--red-500);">- ₹ 0.00</span>
              </div>
              <div class="receipt-line total">
                <span class="rl-label">Net Amount</span>
                <span class="rl-value" id="dispNet">₹ 0.00</span>
              </div>
              <div class="receipt-line">
                <span class="rl-label">Paid</span>
                <span class="rl-value" id="dispPaid">₹ 0.00</span>
              </div>
              <div class="receipt-line balance">
                <span class="rl-label" style="font-weight:700;">Balance Due</span>
                <span class="rl-value" id="dispBalance">₹ 0.00</span>
              </div>
            </div>

          </div>

          <div class="card-footer" style="justify-content:flex-end;gap:12px;">
            <a href="/register" class="btn btn-secondary">
              <i class="fas fa-arrow-left"></i> Back
            </a>
            <button type="submit" class="btn btn-primary btn-lg" id="submitBtn">
              <i class="fas fa-check-circle"></i> Submit Registration
            </button>
          </div>
        </div>

      </form>

    </main>
  </div>
</div>

<script src="/js/main.js"></script>
<script>
  var paymentModeSelect = document.querySelector('select[name="paymentMode"]');
  if (paymentModeSelect) {
    paymentModeSelect.addEventListener('change', function() {
      var label = this.options[this.selectedIndex] ? this.options[this.selectedIndex].text : '';
      document.getElementById('paymentModeName').value = label === 'Select payment mode' ? '' : label;
    });
  }

  function calcAmounts() {
    var gross    = parseFloat(document.getElementById('grossAmount').value)    || 0;
    var visiting = parseFloat(document.getElementById('visitingCharges').value) || 0;
    var discount = parseFloat(document.getElementById('discountAmount').value)  || 0;
    var paid     = parseFloat(document.getElementById('paidAmount').value)      || 0;

    var total   = gross + visiting;
    var net     = Math.max(0, total - discount);
    var balance = Math.max(0, net - paid);

    function fmt(v) {
      return '₹ ' + v.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    document.getElementById('balanceAmount').value     = balance.toFixed(2);
    document.getElementById('dispTotal').textContent   = fmt(total);
    document.getElementById('dispDiscount').textContent = '- ' + fmt(discount);
    document.getElementById('dispNet').textContent     = fmt(net);
    document.getElementById('dispPaid').textContent    = fmt(paid);
    document.getElementById('dispBalance').textContent = fmt(balance);

    var balEl = document.getElementById('dispBalance');
    balEl.style.color = balance > 0 ? 'var(--amber-600)' : 'var(--green-600)';

    var balInput = document.getElementById('balanceAmount');
    balInput.style.color = balance > 0 ? 'var(--amber-600)' : 'var(--green-600)';
  }

  // Show loading on submit
  document.getElementById('finalForm').addEventListener('submit', function() {
    if (paymentModeSelect) {
      var label = paymentModeSelect.options[paymentModeSelect.selectedIndex] ? paymentModeSelect.options[paymentModeSelect.selectedIndex].text : '';
      document.getElementById('paymentModeName').value = label === 'Select payment mode' ? '' : label;
    }
    var btn = document.getElementById('submitBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Saving...';
  });
</script>
</body>
</html>
