<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dashboard — LIMS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/main.css">
  <style>
    .welcome-banner {
      background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 50%, #3b82f6 100%);
      border-radius: var(--radius-xl);
      padding: 28px 32px;
      color: white;
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 24px;
      overflow: hidden;
      position: relative;
    }
    .welcome-banner::before {
      content: '';
      position: absolute;
      top: -40px; right: -40px;
      width: 200px; height: 200px;
      background: rgba(255,255,255,0.06);
      border-radius: 50%;
    }
    .welcome-banner::after {
      content: '';
      position: absolute;
      bottom: -60px; right: 80px;
      width: 250px; height: 250px;
      background: rgba(255,255,255,0.04);
      border-radius: 50%;
    }
    .welcome-text h2 {
      font-size: 1.4rem; font-weight: 800;
      letter-spacing: -0.03em; margin-bottom: 4px;
    }
    .welcome-text p { font-size: 0.875rem; opacity: 0.8; }
    .welcome-icon {
      font-size: 3rem; opacity: 0.2;
      position: relative; z-index: 1;
    }

    /* Quick action cards */
    .quick-actions {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 14px;
      margin-bottom: 28px;
    }
    .quick-card {
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: var(--radius-lg);
      padding: 20px 16px;
      text-align: center;
      cursor: pointer;
      text-decoration: none;
      color: inherit;
      transition: box-shadow var(--transition-base), transform var(--transition-base), border-color var(--transition-base);
      display: flex; flex-direction: column; align-items: center; gap: 10px;
    }
    .quick-card:hover {
      box-shadow: var(--shadow-md);
      transform: translateY(-2px);
      border-color: var(--blue-200);
    }
    .quick-card-icon {
      width: 48px; height: 48px;
      border-radius: var(--radius-md);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.2rem;
    }
    .quick-card-label {
      font-size: 0.8rem; font-weight: 700;
      color: var(--gray-700); text-align: center;
    }

    /* Activity list */
    .activity-item {
      display: flex; align-items: center; gap: 12px;
      padding: 12px 0;
      border-bottom: 1px solid var(--gray-50);
    }
    .activity-item:last-child { border-bottom: none; }
    .activity-dot {
      width: 8px; height: 8px; border-radius: 50%;
      flex-shrink: 0;
    }
    .activity-text { flex: 1; font-size: 0.845rem; color: var(--gray-700); }
    .activity-time { font-size: 0.72rem; color: var(--gray-400); white-space: nowrap; }

    /* Two column layout */
    .dashboard-grid {
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 20px;
    }
    .chart-card {
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-xs);
      margin-bottom: 24px;
      overflow: hidden;
    }
    .chart-head {
      padding: 18px 20px 14px;
      border-bottom: 1px solid var(--gray-100);
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
    }
    .chart-title {
      font-size: 0.96rem;
      font-weight: 700;
      color: var(--gray-900);
    }
    .chart-subtitle {
      font-size: 0.78rem;
      color: var(--gray-400);
      margin-top: 3px;
    }
    .chart-filters {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    .chart-date-group {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .chart-date-label {
      font-size: 0.68rem;
      font-weight: 700;
      color: var(--gray-400);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .chart-date-wrap {
      position: relative;
    }
    .chart-date-input {
      width: 145px;
      padding: 9px 12px;
      border: 1.5px solid var(--gray-200);
      border-radius: var(--radius-md);
      background: var(--white);
      color: var(--gray-700);
      font-size: 0.845rem;
      cursor: pointer;
    }
    .chart-action-btn {
      border: 1px solid var(--gray-200);
      background: var(--white);
      color: var(--gray-600);
      border-radius: var(--radius-lg);
      padding: 10px 14px;
      font-size: 0.8rem;
      font-weight: 700;
      cursor: pointer;
      transition: all var(--transition-fast);
    }
    .chart-action-btn.primary {
      background: var(--blue-600);
      color: #fff;
      border-color: var(--blue-600);
    }
    .chart-body {
      padding: 18px 20px 20px;
    }
    .chart-svg-wrap {
      width: 100%;
      height: 280px;
      background: linear-gradient(180deg, #fbfdff 0%, #ffffff 100%);
      border: 1px solid var(--gray-100);
      border-radius: var(--radius-xl);
      padding: 12px;
    }
    .chart-svg {
      width: 100%;
      height: 100%;
      display: block;
    }
    .chart-summary {
      margin-top: 14px;
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
      font-size: 0.82rem;
      color: var(--gray-500);
    }
    .chart-summary strong {
      color: var(--gray-900);
      font-family: var(--font-mono);
    }
    @media (max-width: 1024px) { .dashboard-grid { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
<div class="app-shell">
  <%- include('partials/sidebar', { activePage: 'dashboard', user: user }) %>

  <div class="main-content">
    <header class="topbar">
      <button class="sidebar-toggle" id="sidebarToggle"><i class="fas fa-bars"></i></button>
      <div class="topbar-title">Dashboard</div>
      <div class="topbar-right">
        <div class="topbar-date"><i class="fas fa-calendar-alt"></i><span id="currentDate"></span></div>
      </div>
    </header>

    <main class="page-content">

      <!-- Welcome Banner -->
      <div class="welcome-banner">
        <div class="welcome-text">
          <h2>Welcome back, <%= user.userName || 'User' %>! 👋</h2>
          <p>Here's what's happening at the lab today.</p>
        </div>
        <i class="fas fa-flask welcome-icon"></i>
      </div>

      <!-- Stats -->
      <div class="stats-grid" style="margin-bottom:28px;">
        <div class="stat-card">
          <div class="stat-icon stat-icon-blue"><i class="fas fa-user-plus"></i></div>
          <div class="stat-body">
            <div class="stat-value"><%= stats.todayPatients %></div>
            <div class="stat-label">Patients Today</div>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon stat-icon-green"><i class="fas fa-users"></i></div>
          <div class="stat-body">
            <div class="stat-value"><%= stats.totalPatients %></div>
            <div class="stat-label">Total Patients</div>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon stat-icon-amber"><i class="fas fa-clock"></i></div>
          <div class="stat-body">
            <div class="stat-value"><%= stats.pendingCollection %></div>
            <div class="stat-label">Pending Collection</div>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon stat-icon-violet"><i class="fas fa-check-double"></i></div>
          <div class="stat-body">
            <div class="stat-value"><%= stats.completedToday %></div>
            <div class="stat-label">Completed Today</div>
          </div>
        </div>
      </div>

      <div class="dashboard-grid">
        <div>
          <!-- Quick Actions -->
          <div style="margin-bottom:8px;">
            <h3 style="font-size:0.9rem;font-weight:700;color:var(--gray-700);margin-bottom:16px;">
              <i class="fas fa-bolt" style="color:var(--blue-500);margin-right:6px;"></i>Quick Actions
            </h3>
            <div class="quick-actions">
              <a href="/register" class="quick-card">
                <div class="quick-card-icon" style="background:var(--blue-50);color:var(--blue-600);">
                  <i class="fas fa-user-plus"></i>
                </div>
                <span class="quick-card-label">New Registration</span>
              </a>
              <a href="/collection" class="quick-card">
                <div class="quick-card-icon" style="background:var(--green-50);color:var(--green-600);">
                  <i class="fas fa-flask"></i>
                </div>
                <span class="quick-card-label">Collection</span>
              </a>
              <a href="/Accession" class="quick-card">
                <div class="quick-card-icon" style="background:var(--violet-50);color:var(--violet-600);">
                  <i class="fas fa-vials"></i>
                </div>
                <span class="quick-card-label">Accession</span>
              </a>
              <a href="/Barcodeprinting" class="quick-card">
                <div class="quick-card-icon" style="background:var(--amber-50);color:var(--amber-600);">
                  <i class="fas fa-barcode"></i>
                </div>
                <span class="quick-card-label">Barcode Print</span>
              </a>
              <a href="/financial-analysis" class="quick-card">
                <div class="quick-card-icon" style="background:#ecfeff;color:#0f766e;">
                  <i class="fas fa-chart-line"></i>
                </div>
                <span class="quick-card-label">Financial Analysis</span>
              </a>
              <a href="/result" class="quick-card">
                <div class="quick-card-icon" style="background:var(--blue-50);color:var(--blue-600);">
                  <i class="fas fa-edit"></i>
                </div>
                <span class="quick-card-label">Result Entry</span>
              </a>
              <a href="/validation" class="quick-card">
                <div class="quick-card-icon" style="background:var(--green-50);color:var(--green-600);">
                  <i class="fas fa-check-circle"></i>
                </div>
                <span class="quick-card-label">Validation</span>
              </a>
              <a href="/reports" class="quick-card">
                <div class="quick-card-icon" style="background:var(--red-50);color:var(--red-500);">
                  <i class="fas fa-file-medical"></i>
                </div>
                <span class="quick-card-label">Reports</span>
              </a>
              <a href="/Search" class="quick-card">
                <div class="quick-card-icon" style="background:var(--gray-100);color:var(--gray-600);">
                  <i class="fas fa-search"></i>
                </div>
                <span class="quick-card-label">Search</span>
              </a>
            </div>
          </div>

          <div class="chart-card">
            <div class="chart-head">
              <div>
                <div class="chart-title">Patient Registration Trend</div>
                <div class="chart-subtitle">Registrations for the selected date range</div>
              </div>
              <div class="chart-filters">
                <div class="chart-date-group">
                  <span class="chart-date-label">From Date</span>
                  <div class="chart-date-wrap">
                    <input type="text" id="trendFromDate" class="chart-date-input" value="<%= fromDate %>" placeholder="DD-MM-YYYY" />
                  </div>
                </div>
                <div class="chart-date-group">
                  <span class="chart-date-label">To Date</span>
                  <div class="chart-date-wrap">
                    <input type="text" id="trendToDate" class="chart-date-input" value="<%= toDate %>" placeholder="DD-MM-YYYY" />
                  </div>
                </div>
                <button type="button" class="chart-action-btn primary" onclick="applyTrendFilter()">Apply</button>
                <button type="button" class="chart-action-btn" onclick="resetTrendFilter()">Reset</button>
              </div>
            </div>
            <div class="chart-body">
              <div class="chart-svg-wrap">
                <svg id="patientTrendChart" class="chart-svg" viewBox="0 0 860 280" preserveAspectRatio="none"></svg>
              </div>
              <div class="chart-summary">
                <span>Total Registrations: <strong id="trendTotal">0</strong></span>
                <span>Average / Day: <strong id="trendAverage">0</strong></span>
                <span>Peak Day: <strong id="trendPeak">-</strong></span>
              </div>
            </div>
          </div>
        </div>

        <!-- Right panel: Lab info -->
        <div>
          <div class="card">
            <div class="card-header">
              <h3 class="card-title"><i class="fas fa-hospital" style="color:var(--blue-500);margin-right:6px;"></i>Lab Info</h3>
            </div>
            <div class="card-body">
              <div style="display:flex;flex-direction:column;gap:14px;">
                <div style="display:flex;align-items:center;gap:12px;">
                  <div style="width:36px;height:36px;border-radius:8px;background:var(--blue-50);display:flex;align-items:center;justify-content:center;color:var(--blue-600);flex-shrink:0;">
                    <i class="fas fa-user-shield"></i>
                  </div>
                  <div>
                    <div style="font-size:0.72rem;color:var(--gray-400);font-weight:600;text-transform:uppercase;letter-spacing:0.06em;">Logged in as</div>
                    <div style="font-size:0.875rem;font-weight:700;color:var(--gray-800);"><%= user.userName || '—' %></div>
                  </div>
                </div>

                <div style="border-top:1px solid var(--gray-100);padding-top:14px;">
                  <div style="font-size:0.72rem;color:var(--gray-400);font-weight:600;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:10px;">System Status</div>
                  <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
                    <span class="status-dot dot-green"></span>
                    <span style="font-size:0.845rem;color:var(--gray-700);">Database Connected</span>
                  </div>
                  <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
                    <span class="status-dot dot-green"></span>
                    <span style="font-size:0.845rem;color:var(--gray-700);">Server Running</span>
                  </div>
                  <div style="display:flex;align-items:center;gap:8px;">
                    <span class="status-dot dot-green"></span>
                    <span style="font-size:0.845rem;color:var(--gray-700);">Session Active</span>
                  </div>
                </div>

                <div style="border-top:1px solid var(--gray-100);padding-top:14px;">
                  <div style="font-size:0.72rem;color:var(--gray-400);font-weight:600;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:8px;">Today</div>
                  <div style="font-size:0.875rem;font-weight:600;color:var(--gray-700);" id="todayFull"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </main>
  </div>
</div>

<script src="/js/main.js"></script>
<script>
  var patientTrendData = <%- JSON.stringify(patientTrend || []) %>;

  var todayEl = document.getElementById('todayFull');
  if (todayEl) {
    todayEl.textContent = new Date().toLocaleDateString('en-IN', {
      weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
    });
  }

  function renderPatientTrend() {
    var svg = document.getElementById('patientTrendChart');
    if (!svg) return;
    var data = patientTrendData.slice();
    if (!data.length) {
      svg.innerHTML = '<text x="50%" y="50%" text-anchor="middle" fill="#94a3b8" font-size="16">No trend data available</text>';
      document.getElementById('trendTotal').textContent = '0';
      document.getElementById('trendAverage').textContent = '0';
      document.getElementById('trendPeak').textContent = '-';
      return;
    }

    var width = 860;
    var height = 280;
    var padLeft = 48;
    var padRight = 18;
    var padTop = 18;
    var padBottom = 42;
    var chartW = width - padLeft - padRight;
    var chartH = height - padTop - padBottom;
    var maxValue = Math.max.apply(null, data.map(function(item) { return item.count; })) || 1;

    var points = data.map(function(item, index) {
      var x = padLeft + (data.length === 1 ? chartW / 2 : (chartW * index / (data.length - 1)));
      var y = padTop + chartH - ((item.count / maxValue) * chartH);
      return { x: x, y: y, label: item.label, count: item.count };
    });

    var linePath = points.map(function(point, index) {
      return (index === 0 ? 'M' : 'L') + point.x.toFixed(2) + ' ' + point.y.toFixed(2);
    }).join(' ');

    var areaPath = linePath + ' L ' + points[points.length - 1].x.toFixed(2) + ' ' + (padTop + chartH) + ' L ' + points[0].x.toFixed(2) + ' ' + (padTop + chartH) + ' Z';

    var gridLines = '';
    for (var i = 0; i <= 4; i++) {
      var y = padTop + (chartH * i / 4);
      var value = Math.round(maxValue - (maxValue * i / 4));
      gridLines += '<line x1="' + padLeft + '" y1="' + y + '" x2="' + (width - padRight) + '" y2="' + y + '" stroke="#e2e8f0" stroke-dasharray="4 6" />';
      gridLines += '<text x="' + (padLeft - 10) + '" y="' + (y + 4) + '" text-anchor="end" fill="#94a3b8" font-size="11">' + value + '</text>';
    }

    var labels = points.map(function(point, index) {
      var shortLabel = point.label.slice(0, 5);
      if (data.length > 15 && index % 2 === 1) shortLabel = '';
      return '<text x="' + point.x + '" y="' + (height - 14) + '" text-anchor="middle" fill="#64748b" font-size="11">' + shortLabel + '</text>';
    }).join('');

    var dots = points.map(function(point) {
      return '<circle cx="' + point.x + '" cy="' + point.y + '" r="4.5" fill="#2563eb" stroke="#ffffff" stroke-width="2"><title>' + point.label + ': ' + point.count + '</title></circle>';
    }).join('');

    svg.innerHTML =
      '<defs><linearGradient id="trendFill" x1="0" x2="0" y1="0" y2="1"><stop offset="0%" stop-color="#93c5fd" stop-opacity="0.45"/><stop offset="100%" stop-color="#93c5fd" stop-opacity="0.04"/></linearGradient></defs>' +
      gridLines +
      '<path d="' + areaPath + '" fill="url(#trendFill)" />' +
      '<path d="' + linePath + '" fill="none" stroke="#2563eb" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />' +
      dots +
      labels;

    var total = data.reduce(function(sum, item) { return sum + item.count; }, 0);
    var peak = data.reduce(function(best, item) { return item.count > best.count ? item : best; }, data[0]);
    document.getElementById('trendTotal').textContent = total;
    document.getElementById('trendAverage').textContent = (total / data.length).toFixed(1);
    document.getElementById('trendPeak').textContent = peak.label + ' (' + peak.count + ')';
  }

  initDatePicker('trendFromDate');
  initDatePicker('trendToDate');

  function applyTrendFilter() {
    var from = document.getElementById('trendFromDate').value;
    var to = document.getElementById('trendToDate').value;
    if (!from || !to) {
      showToast('Please select both From Date and To Date', 'warning');
      return;
    }
    window.location.href = '/dashboard?fromDate=' + encodeURIComponent(from) + '&toDate=' + encodeURIComponent(to);
  }

  function resetTrendFilter() {
    window.location.href = '/dashboard';
  }

  renderPatientTrend();
</script>
</body>
</html>
