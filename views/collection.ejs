<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Collection — LIMS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
<div class="app-shell">
  <%- include('partials/sidebar', { activePage: 'collection', user: user }) %>

  <div class="main-content">
    <header class="topbar">
      <button class="sidebar-toggle" id="sidebarToggle"><i class="fas fa-bars"></i></button>
      <div class="topbar-title">Sample Collection</div>
      <div class="topbar-right">
        <div class="topbar-date"><i class="fas fa-calendar-alt"></i><span id="currentDate"></span></div>
      </div>
    </header>

    <main class="page-content">

      <!-- Filter bar -->
      <div class="filter-bar">
        <div class="form-group">
          <label class="form-label">From Date</label>
          <div style="position:relative;">
            <input type="text" id="fromDate" class="form-control" placeholder="DD-MM-YYYY"
              value="<%= typeof fromDate !== 'undefined' ? fromDate : '' %>" />
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">To Date</label>
          <div style="position:relative;">
            <input type="text" id="toDate" class="form-control" placeholder="DD-MM-YYYY"
              value="<%= typeof toDate !== 'undefined' ? toDate : '' %>" />
          </div>
        </div>
        <button class="btn btn-primary" onclick="applyFilter()"><i class="fas fa-search"></i> Filter</button>
        <button class="btn btn-secondary" onclick="clearFilter()"><i class="fas fa-times"></i> Clear</button>
        <div style="flex:1;"></div>
        <button class="btn btn-secondary" onclick="bulkAction()" id="bulkBtn" disabled>
          <i class="fas fa-layer-group"></i> Bulk Action
        </button>
      </div>

      <!-- Stats -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon stat-icon-blue"><i class="fas fa-users"></i></div>
          <div class="stat-body">
            <div class="stat-value" id="statTotal"><%= data.length %></div>
            <div class="stat-label">Total Records</div>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon stat-icon-amber"><i class="fas fa-clock"></i></div>
          <div class="stat-body">
            <div class="stat-value" id="statPending">0</div>
            <div class="stat-label">Pending</div>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon stat-icon-green"><i class="fas fa-check"></i></div>
          <div class="stat-body">
            <div class="stat-value" id="statCollected">0</div>
            <div class="stat-label">Collected</div>
          </div>
        </div>
      </div>

      <!-- Table -->
      <div class="card">
        <div class="table-toolbar">
          <div class="table-search">
            <i class="fas fa-search"></i>
            <input type="text" class="form-control" id="tableSearch" placeholder="Search patient, visit, test..." />
          </div>
          <select class="form-control" id="statusFilter" onchange="filterByStatus()" style="width:160px;">
            <option value="">All Statuses</option>
            <option value="Pending">Pending</option>
            <option value="Collected">Collected</option>
            <option value="Hold">Hold</option>
            <option value="Rejected">Rejected</option>
          </select>
          <label class="check-wrapper">
            <input type="checkbox" id="selectAll" onchange="toggleSelectAll(this)" /> Select All
          </label>
        </div>

        <div class="table-wrapper">
          <table class="data-table" id="collectionTable">
            <thead>
              <tr>
                <th class="col-check"><input type="checkbox" id="headerCheck" onchange="toggleSelectAll(this)" /></th>
                <th>Visit Code</th>
                <th>Patient</th>
                <th>Test / Profile</th>
                <th>Visit Date</th>
                <th>Status</th>
                <th>Action</th>
                <th class="col-actions">View</th>
              </tr>
            </thead>
            <tbody>
              <% if (data && data.length > 0) { %>
                <% data.forEach(function(row, i) { %>
                <tr data-visit-trans="<%= row.VisitTransID %>" data-test="<%= row.TestID %>">
                  <td><input type="checkbox" class="row-check" onchange="onRowCheck()" /></td>
                  <td><span class="mono text-sm" style="font-weight:600;color:var(--blue-700);"><%= row.VisitCode || '—' %></span></td>
                  <td>
                    <strong><%= row.PatientName || '—' %></strong>
                    <div class="text-xs text-muted">
                      <%= row.Age ? row.Age + (row.AgeType || '') : '' %>
                      <% if (row.Gender) { %> · <%= row.Gender %><% } %>
                    </div>
                  </td>
                  <td><%= row.TestName || row.ProfileName || '—' %></td>
                  <td class="text-sm"><%= row.VisitDateTime || '—' %></td>
                  <td>
                    <span class="badge <%=
                      row.StatusName === 'Sample Collect' ? 'badge-green' :
                      row.StatusName === 'Sample Hold'    ? 'badge-amber' :
                      row.StatusName === 'Sample Reject'  ? 'badge-red'   :
                      row.StatusName === 'Pending'        ? 'badge-gray'  : 'badge-gray'
                    %>">
                      <span class="status-dot <%=
                        row.StatusName === 'Sample Collect' ? 'dot-green' :
                        row.StatusName === 'Sample Hold'    ? 'dot-amber' :
                        row.StatusName === 'Sample Reject'  ? 'dot-red'   : 'dot-gray'
                      %>"></span>
                      <%= row.StatusName || 'Pending' %>
                    </span>
                  </td>
                  <td>
                    <select class="form-control" style="width:130px;font-size:0.78rem;padding:5px 8px;"
                      onchange="updateAction(this, '<%= row.VisitTransID %>', '<%= row.TestID %>')">
                      <option value="">— Action —</option>
                      <option value="3">Collected</option>
                      <option value="4">Rejected</option>
                      <option value="5">Hold</option>
                    </select>
                  </td>
                  <td class="col-actions text-right">
                    <button class="btn btn-ghost btn-sm" onclick="viewPatient('<%= row.VisitCode %>')" title="View">
                      <i class="fas fa-eye"></i>
                    </button>
                  </td>
                </tr>
                <% }); %>
              <% } else { %>
              <tr>
                <td colspan="8" style="text-align:center;padding:40px;color:var(--gray-400);">
                  <i class="fas fa-flask" style="font-size:2rem;margin-bottom:10px;display:block;opacity:0.4;"></i>
                  No collection records found. Apply date filter to load data.
                </td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <div class="pagination">
          <span class="pagination-info">Showing <strong><%= data ? data.length : 0 %></strong> records</span>
        </div>
      </div>

    </main>
  </div>
</div>

<!-- Bulk Action Modal -->
<div class="modal-backdrop" id="bulkModal">
  <div class="modal">
    <div class="modal-header">
      <h3 class="modal-title">Bulk Status Update</h3>
      <button class="modal-close" data-modal-close><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body">
      <p class="text-sm text-muted mb-16">Select an action to apply to all <strong id="selectedCount">0</strong> selected rows.</p>
      <div class="form-group">
        <label class="form-label">Action</label>
        <select class="form-control" id="bulkActionSelect">
          <option value="">— Select Action —</option>
          <option value="3">Collected</option>
          <option value="4">Rejected</option>
          <option value="5">Hold</option>
        </select>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" data-modal-close>Cancel</button>
      <button class="btn btn-primary" onclick="submitBulkAction()">Apply Action</button>
    </div>
  </div>
</div>

<script src="/js/main.js"></script>
<script>
  // ── Table search ──
  initTableSearch('tableSearch', 'collectionTable');

  // ── Date pickers ──
  initDatePicker('fromDate');
  initDatePicker('toDate');

  // ── Filter ──
  function applyFilter() {
    var from = document.getElementById('fromDate').value;
    var to   = document.getElementById('toDate').value;
    if (!from || !to) { showToast('Please select both From and To dates', 'warning'); return; }
    window.location.href = '/collection?FromDate=' + encodeURIComponent(from) + '&ToDate=' + encodeURIComponent(to);
  }

  function clearFilter() {
    window._dpClear('fromDate');
    window._dpClear('toDate');
    window.location.href = '/collection';
  }

  // ── Action update ──
  function updateAction(sel, visitTransID, testID) {
    var actionID = sel.value;
    if (!actionID) return;
    fetch('/update-action', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ VisitTransID: visitTransID, TestID: testID, ActionID: actionID })
    }).then(function(r) {
      if (r.ok) showToast('Status updated successfully', 'success');
      else showToast('Failed to update status', 'error');
    }).catch(function() { showToast('Network error', 'error'); });
  }

  // ── Row selection ──
  function onRowCheck() {
    var checked = document.querySelectorAll('.row-check:checked').length;
    document.getElementById('bulkBtn').disabled = checked === 0;
    document.getElementById('selectedCount').textContent = checked;
  }

  function toggleSelectAll(cb) {
    document.querySelectorAll('.row-check').forEach(function(c) { c.checked = cb.checked; });
    onRowCheck();
  }

  // ── Bulk action ──
  function bulkAction() {
    var checked = document.querySelectorAll('.row-check:checked').length;
    if (!checked) return;
    document.getElementById('selectedCount').textContent = checked;
    openModal('bulkModal');
  }

  function submitBulkAction() {
    var actionID = document.getElementById('bulkActionSelect').value;
    if (!actionID) { showToast('Please select an action', 'warning'); return; }
    var rows = [];
    document.querySelectorAll('tbody tr').forEach(function(tr) {
      var cb = tr.querySelector('.row-check');
      if (cb && cb.checked) rows.push({ visitTransID: tr.dataset.visitTrans, testID: tr.dataset.test });
    });
    fetch('/update-bulk-action', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ actionID: actionID, rows: rows })
    }).then(function(r) {
      if (r.ok) { showToast('Updated ' + rows.length + ' records', 'success'); closeModal('bulkModal'); }
      else showToast('Failed to update', 'error');
    });
  }

  // ── View patient ──
  function viewPatient(visitCode) {
    window.open('/reports/preview/' + visitCode, '_blank');
  }

  // ── Status filter ──
  function filterByStatus() {
    var val = document.getElementById('statusFilter').value.toLowerCase();
    document.querySelectorAll('#collectionTable tbody tr').forEach(function(tr) {
      var statusCell = tr.querySelector('td:nth-child(6)');
      tr.style.display = !val || (statusCell && statusCell.textContent.toLowerCase().includes(val)) ? '' : 'none';
    });
  }

  // ── Count stats ──
  var rows = document.querySelectorAll('#collectionTable tbody tr');
  var pending = 0, collected = 0;
  rows.forEach(function(tr) {
    var t = (tr.querySelector('td:nth-child(6)') ? tr.querySelector('td:nth-child(6)').textContent.trim() : '');
    if (t.includes('Pending'))  pending++;
    if (t.includes('Collect'))  collected++;
  });
  document.getElementById('statPending').textContent   = pending;
  document.getElementById('statCollected').textContent = collected;
</script>
</body>
</html>