<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Financial Analysis - LIMS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/main.css">
  <style>
    .finance-hero {
      background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 55%, #2563eb 100%);
      border-radius: var(--radius-xl);
      padding: 28px 30px;
      margin-bottom: 24px;
      color: #fff;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 18px;
      flex-wrap: wrap;
    }
    .finance-hero h2 {
      font-size: 1.45rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      margin-bottom: 6px;
    }
    .finance-hero p {
      font-size: 0.88rem;
      opacity: 0.78;
      max-width: 560px;
    }
    .finance-filter {
      display: flex;
      gap: 10px;
      align-items: flex-end;
      flex-wrap: wrap;
    }
    .finance-filter .hero-date-group {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .finance-filter .hero-date-label {
      font-size: 0.68rem;
      font-weight: 700;
      color: rgba(255,255,255,0.75);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .finance-filter .hero-date-wrap {
      position: relative;
    }
    .finance-filter .hero-date-input {
      width: 145px;
      padding: 9px 32px 9px 12px;
      background: rgba(255,255,255,0.12);
      border: 1.5px solid rgba(255,255,255,0.2);
      border-radius: var(--radius-md);
      color: #fff;
      font-size: 0.845rem;
      cursor: pointer;
    }
    .finance-filter .hero-date-input::placeholder {
      color: rgba(255,255,255,0.5);
    }
    .finance-btn {
      padding: 11px 16px;
      border-radius: var(--radius-lg);
      font-weight: 700;
      font-size: 0.85rem;
      border: none;
      cursor: pointer;
    }
    .finance-btn.primary {
      background: #fff;
      color: var(--blue-700);
    }
    .finance-btn.secondary {
      background: rgba(255,255,255,0.12);
      color: #fff;
      border: 1.5px solid rgba(255,255,255,0.2);
    }
    .finance-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
      margin-bottom: 22px;
    }
    .finance-card {
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: var(--radius-xl);
      padding: 18px;
      box-shadow: var(--shadow-xs);
    }
    .finance-card-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 10px;
    }
    .finance-card-label {
      font-size: 0.74rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--gray-400);
      font-weight: 700;
    }
    .finance-card-icon {
      width: 38px;
      height: 38px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
    }
    .finance-value {
      font-size: 1.45rem;
      font-weight: 800;
      color: var(--gray-900);
      letter-spacing: -0.03em;
    }
    .finance-sub {
      margin-top: 4px;
      font-size: 0.8rem;
      color: var(--gray-500);
    }
    .analysis-layout {
      display: grid;
      grid-template-columns: 1.4fr 1fr;
      gap: 18px;
    }
    .analysis-stack {
      display: grid;
      gap: 18px;
    }
    .section-card {
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-xs);
      overflow: hidden;
    }
    .section-head {
      padding: 18px 20px 14px;
      border-bottom: 1px solid var(--gray-100);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }
    .section-title {
      font-size: 0.96rem;
      font-weight: 700;
      color: var(--gray-900);
    }
    .section-sub {
      font-size: 0.78rem;
      color: var(--gray-400);
    }
    .section-body {
      padding: 18px 20px 20px;
    }
    .trend-list {
      display: grid;
      gap: 14px;
    }
    .trend-row {
      display: grid;
      grid-template-columns: 88px 1fr 88px;
      gap: 12px;
      align-items: center;
    }
    .trend-date {
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--gray-700);
    }
    .trend-bar-wrap {
      height: 12px;
      border-radius: 999px;
      background: var(--gray-100);
      overflow: hidden;
      position: relative;
    }
    .trend-bar {
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, #93c5fd 0%, #2563eb 100%);
    }
    .trend-value {
      text-align: right;
      font-family: var(--font-mono);
      font-size: 0.84rem;
      font-weight: 700;
      color: var(--gray-800);
    }
    .mode-list,
    .due-list {
      display: grid;
      gap: 12px;
    }
    .finance-table-wrap {
      border: 1px solid var(--gray-100);
      border-radius: 18px;
      overflow: hidden;
      background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
    }
    .finance-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      table-layout: fixed;
    }
    .finance-table thead th {
      background: #f8fafc;
      color: var(--gray-500);
      font-size: 0.73rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      padding: 12px 14px;
      border: none;
      border-bottom: 1px solid var(--gray-200);
    }
    .finance-table tbody td {
      padding: 14px;
      border: none;
      border-bottom: 1px solid var(--gray-100);
      color: var(--gray-800);
      font-size: 0.88rem;
      background: transparent;
    }
    .finance-table tbody tr:last-child td {
      border-bottom: none;
    }
    .finance-table tbody tr:nth-child(even) td {
      background: rgba(248, 250, 252, 0.7);
    }
    .finance-table tbody tr:hover td {
      background: rgba(219, 234, 254, 0.35);
    }
    .finance-table .cell-date {
      font-weight: 700;
      color: var(--gray-700);
    }
    .finance-table .cell-center {
      text-align: center;
      font-weight: 700;
      color: var(--gray-600);
    }
    .finance-table .cell-money {
      text-align: right;
      font-family: var(--font-mono);
      font-weight: 700;
      white-space: nowrap;
    }
    .finance-table .money-net {
      color: var(--blue-700);
    }
    .finance-table .money-paid {
      color: var(--green-700);
    }
    .finance-table .money-due {
      color: var(--amber-700);
    }
    .mode-row,
    .due-row {
      padding: 12px 14px;
      border: 1px solid var(--gray-100);
      border-radius: var(--radius-lg);
      background: var(--gray-50);
    }
    .mode-top,
    .due-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 6px;
    }
    .mode-name,
    .due-name {
      font-weight: 700;
      color: var(--gray-800);
    }
    .mode-value,
    .due-value {
      font-family: var(--font-mono);
      font-weight: 700;
      color: var(--gray-900);
    }
    .mode-bar-wrap {
      height: 8px;
      border-radius: 999px;
      background: #e7eef9;
      overflow: hidden;
    }
    .mode-bar {
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, #60a5fa 0%, #0f766e 100%);
    }
    .due-meta,
    .mode-meta {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
      font-size: 0.78rem;
      color: var(--gray-500);
    }
    .mono {
      font-family: var(--font-mono);
    }
    .empty-state {
      text-align: center;
      color: var(--gray-400);
      padding: 24px 12px;
      font-size: 0.88rem;
    }
    @media (max-width: 1180px) {
      .finance-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .analysis-layout {
        grid-template-columns: 1fr;
      }
    }
    @media (max-width: 680px) {
      .finance-grid {
        grid-template-columns: 1fr;
      }
      .trend-row {
        grid-template-columns: 1fr;
      }
      .trend-value {
        text-align: left;
      }
      .finance-table {
        table-layout: auto;
      }
    }
  </style>
</head>
<body>
<%
  function formatMoney(value) {
    return 'Rs ' + Number(value || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
%>
<div class="app-shell">
  <%- include('partials/sidebar', { activePage: 'financial-analysis', user: user }) %>

  <div class="main-content">
    <header class="topbar">
      <button class="sidebar-toggle" id="sidebarToggle"><i class="fas fa-bars"></i></button>
      <div class="topbar-title">Financial Analysis</div>
      <div class="topbar-right">
        <div class="topbar-date"><i class="fas fa-calendar-alt"></i><span id="currentDate"></span></div>
      </div>
    </header>

    <main class="page-content">
      <div class="finance-hero">
        <div>
          <h2>Financial Analysis</h2>
          <p>Track collections, discounts, dues, and payment mix across your selected billing period.</p>
        </div>
        <div class="finance-filter">
          <div class="hero-date-group">
            <span class="hero-date-label">From Date</span>
            <div class="hero-date-wrap">
              <input type="text" id="fromDate" class="hero-date-input" value="<%= fromDate %>" placeholder="DD-MM-YYYY" />
            </div>
          </div>
          <div class="hero-date-group">
            <span class="hero-date-label">To Date</span>
            <div class="hero-date-wrap">
              <input type="text" id="toDate" class="hero-date-input" value="<%= toDate %>" placeholder="DD-MM-YYYY" />
            </div>
          </div>
          <button class="finance-btn primary" onclick="applyFinancialFilter()"><i class="fas fa-search"></i> Apply</button>
          <button class="finance-btn secondary" onclick="clearFinancialFilter()"><i class="fas fa-times"></i> Reset</button>
        </div>
      </div>

      <div class="finance-grid">
        <div class="finance-card">
          <div class="finance-card-head">
            <div class="finance-card-label">Net Revenue</div>
            <div class="finance-card-icon" style="background:var(--blue-50);color:var(--blue-600);"><i class="fas fa-indian-rupee-sign"></i></div>
          </div>
          <div class="finance-value"><%= formatMoney(summary.NetAmount || 0) %></div>
          <div class="finance-sub"><%= summary.VisitCount || 0 %> billed visits in selected range</div>
        </div>
        <div class="finance-card">
          <div class="finance-card-head">
            <div class="finance-card-label">Collected</div>
            <div class="finance-card-icon" style="background:var(--green-50);color:var(--green-600);"><i class="fas fa-wallet"></i></div>
          </div>
          <div class="finance-value"><%= formatMoney(summary.PaidAmount || 0) %></div>
          <div class="finance-sub">Payments received from patients</div>
        </div>
        <div class="finance-card">
          <div class="finance-card-head">
            <div class="finance-card-label">Outstanding</div>
            <div class="finance-card-icon" style="background:var(--amber-50);color:var(--amber-600);"><i class="fas fa-clock"></i></div>
          </div>
          <div class="finance-value"><%= formatMoney(summary.BalanceAmount || 0) %></div>
          <div class="finance-sub">Current due balance pending collection</div>
        </div>
        <div class="finance-card">
          <div class="finance-card-head">
            <div class="finance-card-label">Discount Given</div>
            <div class="finance-card-icon" style="background:var(--red-50);color:var(--red-500);"><i class="fas fa-percent"></i></div>
          </div>
          <div class="finance-value"><%= formatMoney(summary.DiscountAmount || 0) %></div>
          <div class="finance-sub">Gross: <span class="mono"><%= formatMoney(summary.GrossAmount || 0) %></span></div>
        </div>
      </div>

      <div class="analysis-layout">
        <div class="analysis-stack">
          <div class="section-card">
            <div class="section-head">
              <div>
                <div class="section-title">Daily Revenue Trend</div>
                <div class="section-sub">Net billed amount by day</div>
              </div>
            </div>
            <div class="section-body">
              <% if (daily.length) { %>
                <div class="trend-list">
                  <% daily.forEach(function(row) { %>
                    <div class="trend-row">
                      <div class="trend-date"><%= row.VisitDateLabel %></div>
                      <div class="trend-bar-wrap">
                        <div class="trend-bar" style="width:<%= Math.max(8, Math.round((Number(row.NetAmount || 0) / maxDailyNet) * 100)) %>%"></div>
                      </div>
                      <div class="trend-value"><%= formatMoney(row.NetAmount || 0) %></div>
                    </div>
                  <% }); %>
                </div>
              <% } else { %>
                <div class="empty-state">No billing records found for the selected dates.</div>
              <% } %>
            </div>
          </div>

          <div class="section-card">
            <div class="section-head">
              <div>
                <div class="section-title">Daily Collection Snapshot</div>
                <div class="section-sub">Visits, paid amount, and due amount by date</div>
              </div>
            </div>
            <div class="section-body">
              <% if (daily.length) { %>
                <div class="finance-table-wrap">
                  <table class="finance-table">
                    <thead>
                      <tr>
                        <th style="width: 24%;">Date</th>
                        <th style="width: 12%; text-align:center;">Visits</th>
                        <th style="width: 21%; text-align:right;">Net</th>
                        <th style="width: 21%; text-align:right;">Paid</th>
                        <th style="width: 22%; text-align:right;">Due</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% daily.forEach(function(row) { %>
                        <tr>
                          <td class="cell-date"><%= row.VisitDateLabel %></td>
                          <td class="cell-center"><%= row.VisitCount %></td>
                          <td class="cell-money money-net"><%= formatMoney(row.NetAmount || 0) %></td>
                          <td class="cell-money money-paid"><%= formatMoney(row.PaidAmount || 0) %></td>
                          <td class="cell-money money-due"><%= formatMoney(row.BalanceAmount || 0) %></td>
                        </tr>
                      <% }); %>
                    </tbody>
                  </table>
                </div>
              <% } else { %>
                <div class="empty-state">No daily collection data available.</div>
              <% } %>
            </div>
          </div>
        </div>

        <div class="analysis-stack">
          <div class="section-card">
            <div class="section-head">
              <div>
                <div class="section-title">Payment Mode Split</div>
                <div class="section-sub">Collected amount by payment mode</div>
              </div>
            </div>
            <div class="section-body">
              <% if (paymentModes.length) { %>
                <div class="mode-list">
                  <% paymentModes.forEach(function(mode) { %>
                    <div class="mode-row">
                      <div class="mode-top">
                        <div class="mode-name"><%= mode.PaymentMode || 'Unknown' %></div>
                        <div class="mode-value"><%= formatMoney(mode.PaidAmount || 0) %></div>
                      </div>
                      <div class="mode-bar-wrap">
                        <div class="mode-bar" style="width:<%= Math.max(6, Math.round((Number(mode.PaidAmount || 0) / totalPaidForModes) * 100)) %>%"></div>
                      </div>
                      <div class="mode-meta" style="margin-top:6px;">
                        <span><%= mode.VisitCount %> visits</span>
                        <span>Net: <span class="mono"><%= formatMoney(mode.NetAmount || 0) %></span></span>
                      </div>
                    </div>
                  <% }); %>
                </div>
              <% } else { %>
                <div class="empty-state">No payment mode records available.</div>
              <% } %>
            </div>
          </div>

          <div class="section-card">
            <div class="section-head">
              <div>
                <div class="section-title">Highest Due Visits</div>
                <div class="section-sub">Top pending balances in selected period</div>
              </div>
            </div>
            <div class="section-body">
              <% if (dueVisits.length) { %>
                <div class="due-list">
                  <% dueVisits.forEach(function(row) { %>
                    <div class="due-row">
                      <div class="due-top">
                        <div class="due-name"><%= row.PatientName || 'Unknown Patient' %></div>
                        <div class="due-value"><%= formatMoney(row.BalanceAmount || 0) %></div>
                      </div>
                      <div class="due-meta">
                        <span><strong><%= row.VisitCode %></strong></span>
                        <span><%= row.VisitDateLabel %></span>
                      </div>
                      <div class="due-meta" style="margin-top:4px;">
                        <span>Net: <span class="mono"><%= formatMoney(row.NetAmount || 0) %></span></span>
                        <span>Paid: <span class="mono"><%= formatMoney(row.PaidAmount || 0) %></span></span>
                      </div>
                    </div>
                  <% }); %>
                </div>
              <% } else { %>
                <div class="empty-state">No outstanding balances found for the selected dates.</div>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>

<script src="/js/main.js"></script>
<script>
  initDatePicker('fromDate');
  initDatePicker('toDate');

  function applyFinancialFilter() {
    var from = document.getElementById('fromDate').value;
    var to = document.getElementById('toDate').value;
    if (!from || !to) {
      showToast('Please select both From Date and To Date', 'warning');
      return;
    }
    window.location.href = '/financial-analysis?fromDate=' + encodeURIComponent(from) + '&toDate=' + encodeURIComponent(to);
  }

  function clearFinancialFilter() {
    window.location.href = '/financial-analysis';
  }
  </script>
</body>
</html>
