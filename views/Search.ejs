<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Search — LIMS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/main.css">
  <style>
    .search-hero {
      background: linear-gradient(135deg, var(--blue-600) 0%, var(--blue-800) 100%);
      border-radius: var(--radius-xl);
      padding: 32px 32px 28px;
      margin-bottom: 24px;
      color: white;
    }
    .search-hero h2 { font-size: 1.3rem; font-weight: 800; letter-spacing: -0.03em; margin-bottom: 6px; }
    .search-hero p { font-size: 0.855rem; opacity: 0.75; margin-bottom: 20px; }
    .search-box-wrapper { display: flex; gap: 10px; align-items: flex-end; flex-wrap: wrap; }
    .search-box-inner { flex: 1; position: relative; min-width: 200px; max-width: 500px; }
    .search-box-inner i {
      position: absolute; left: 14px; top: 50%;
      transform: translateY(-50%);
      color: rgba(255,255,255,0.5); font-size: 0.9rem; pointer-events: none;
    }
    .search-input {
      width: 100%; padding: 11px 14px 11px 42px;
      background: rgba(255,255,255,0.15);
      border: 1.5px solid rgba(255,255,255,0.25);
      border-radius: var(--radius-lg);
      color: white; font-size: 0.95rem; font-family: var(--font-sans);
      outline: none;
      transition: background var(--transition-fast), border-color var(--transition-fast);
    }
    .search-input::placeholder { color: rgba(255,255,255,0.45); }
    .search-input:focus { background: rgba(255,255,255,0.22); border-color: rgba(255,255,255,0.5); }

    /* White date picker inputs inside blue hero */
    .hero-date-group { display: flex; flex-direction: column; gap: 4px; }
    .hero-date-label { font-size: 0.68rem; font-weight: 700; color: rgba(255,255,255,0.7); text-transform: uppercase; letter-spacing: 0.06em; }
    .hero-date-wrap { position: relative; }
    .hero-date-input {
      padding: 9px 32px 9px 12px;
      background: rgba(255,255,255,0.15);
      border: 1.5px solid rgba(255,255,255,0.3);
      border-radius: var(--radius-md);
      color: white; font-size: 0.845rem;
      font-family: var(--font-sans);
      outline: none; cursor: pointer; width: 145px;
    }
    .hero-date-input::placeholder { color: rgba(255,255,255,0.5); }

    .search-btn-white {
      padding: 11px 20px;
      background: white; color: var(--blue-700);
      border: none; border-radius: var(--radius-lg);
      font-weight: 700; font-size: 0.855rem; font-family: var(--font-sans);
      cursor: pointer; white-space: nowrap;
      transition: all var(--transition-fast);
      align-self: flex-end;
    }
    .search-btn-white:hover { background: var(--blue-50); }
    .clear-btn-white {
      padding: 11px 14px;
      background: rgba(255,255,255,0.15); color: white;
      border: 1.5px solid rgba(255,255,255,0.25); border-radius: var(--radius-lg);
      font-weight: 600; font-size: 0.845rem; font-family: var(--font-sans);
      cursor: pointer; white-space: nowrap;
      transition: all var(--transition-fast);
      align-self: flex-end;
    }
    .clear-btn-white:hover { background: rgba(255,255,255,0.25); }

    .result-card {
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: var(--radius-lg);
      padding: 18px 20px;
      display: flex; align-items: flex-start; gap: 16px;
      transition: box-shadow var(--transition-base), border-color var(--transition-base);
      cursor: pointer;
    }
    .result-card:hover { box-shadow: var(--shadow-md); border-color: var(--blue-200); }
    .result-avatar {
      width: 40px; height: 40px; border-radius: 50%;
      background: var(--blue-100); color: var(--blue-700);
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: 0.9rem; flex-shrink: 0;
    }
    .result-card-body { flex: 1; min-width: 0; }
    .rc-name { font-size: 0.9rem; font-weight: 700; color: var(--gray-900); }
    .rc-meta { font-size: 0.78rem; color: var(--gray-500); margin-top: 3px; display: flex; gap: 14px; flex-wrap: wrap; }
    .rc-meta span { display: flex; align-items: center; gap: 4px; }
    .rc-actions { display: flex; gap: 6px; flex-shrink: 0; flex-wrap: wrap; justify-content: flex-end; }
    .results-grid { display: flex; flex-direction: column; gap: 10px; }
    .results-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
    .pending-amount {
      font-weight: 700;
      color: var(--amber-600);
      font-family: var(--font-mono);
    }
    .paid-amount {
      font-weight: 700;
      color: var(--green-700);
      font-family: var(--font-mono);
    }
  </style>
</head>
<body>
<div class="app-shell">
  <%- include('partials/sidebar', { activePage: 'search', user: typeof user !== 'undefined' ? user : null }) %>

  <div class="main-content">
    <header class="topbar">
      <button class="sidebar-toggle" id="sidebarToggle"><i class="fas fa-bars"></i></button>
      <div class="topbar-title">Patient Search</div>
      <div class="topbar-right">
        <div class="topbar-date"><i class="fas fa-calendar-alt"></i><span id="currentDate"></span></div>
      </div>
    </header>

    <main class="page-content">

      <!-- Search Hero -->
      <div class="search-hero">
        <h2>Patient Search</h2>
        <p>Find patients by name, visit code, mobile number or date range</p>
        <div class="search-box-wrapper">

          <!-- Live search -->
          <div class="search-box-inner">
            <i class="fas fa-search"></i>
            <input type="text" class="search-input" id="liveSearch"
              placeholder="Type name, visit code or mobile..."
              oninput="liveFilter(this.value)" />
          </div>

          <!-- From Date -->
          <div class="hero-date-group">
            <span class="hero-date-label">From Date</span>
            <div class="hero-date-wrap">
              <input type="text" id="fromDate" class="hero-date-input" placeholder="DD-MM-YYYY"
                value="<%= typeof fromDate !== 'undefined' ? fromDate : '' %>" />
            </div>
          </div>

          <!-- To Date -->
          <div class="hero-date-group">
            <span class="hero-date-label">To Date</span>
            <div class="hero-date-wrap">
              <input type="text" id="toDate" class="hero-date-input" placeholder="DD-MM-YYYY"
                value="<%= typeof toDate !== 'undefined' ? toDate : '' %>" />
            </div>
          </div>

          <button class="search-btn-white" onclick="applyFilter()">
            <i class="fas fa-search"></i> Search
          </button>
          <button class="clear-btn-white" onclick="clearFilter()">
            <i class="fas fa-times"></i> Clear
          </button>

        </div>
      </div>

      <!-- Results -->
      <% if (data && data.length > 0) { %>
      <div class="results-header">
        <span class="text-sm text-muted"><strong><%= data.length %></strong> records found</span>
        <div class="flex gap-8">
          <select class="form-control" style="width:160px;font-size:0.8rem;" onchange="sortResults(this.value)">
            <option value="">Sort by...</option>
            <option value="name">Name (A–Z)</option>
            <option value="code">Visit Code</option>
          </select>
        </div>
      </div>

      <div class="results-grid" id="resultsGrid">
        <% data.forEach(function(row) { %>
        <div class="result-card"
             data-name="<%= (row.PatientName || '').toLowerCase() %>"
             data-code="<%= (row.VisitCode || '').toLowerCase() %>"
             data-phone="<%= (row.MobileNo || '').toLowerCase() %>"
             onclick="window.location.href='/reports/preview/<%= row.VisitCode %>'">
          <div class="result-avatar"><%= (row.PatientName || 'P')[0].toUpperCase() %></div>
          <div class="result-card-body">
            <div class="rc-name"><%= row.PatientName || '—' %></div>
            <div class="rc-meta">
              <span><i class="fas fa-id-badge" style="color:var(--blue-400);"></i>
                <strong style="font-family:var(--font-mono);color:var(--blue-700);"><%= row.VisitCode || '—' %></strong>
              </span>
              <% if (row.Age) { %>
              <span><i class="fas fa-user"></i> <%= row.Age %><%= row.AgeType || '' %> / <%= row.Gender || '?' %></span>
              <% } %>
              <% if (row.VisitDateTime) { %>
              <span><i class="fas fa-calendar"></i> <%= row.VisitDateTime %></span>
              <% } %>
              <% if (row.TestName) { %>
              <span><i class="fas fa-flask"></i> <%= row.TestName %></span>
              <% } %>
              <% if (row.StatusName) { %>
              <span>
                <span class="badge <%=
                  row.StatusName === 'Validated'     ? 'badge-green' :
                  row.StatusName === 'Sample Collect'? 'badge-blue'  :
                  row.StatusName === 'Pending'       ? 'badge-amber' : 'badge-gray'
                %>" style="font-size:0.68rem;"><%= row.StatusName %></span>
              </span>
              <% } %>
              <% if (typeof row.BalanceAmount !== 'undefined') { %>
              <span>
                <span class="badge <%= row.BalanceAmount > 0 ? 'badge-amber' : 'badge-green' %>" style="font-size:0.68rem;">
                  <%= row.PaymentStatus %>
                </span>
              </span>
              <span>
                <i class="fas fa-wallet"></i>
                <% if (row.BalanceAmount > 0) { %>
                  <span class="pending-amount">Pending: <%= Number(row.BalanceAmount || 0).toFixed(2) %></span>
                <% } else { %>
                  <span class="paid-amount">Paid</span>
                <% } %>
              </span>
              <% } %>
            </div>
          </div>
          <div class="rc-actions" onclick="event.stopPropagation()">
            <% if (row.VisitID) { %>
            <a href="/invoice/<%= row.VisitID %>" class="btn btn-ghost btn-sm" title="Invoice" onclick="event.stopPropagation(); return openInvoicePopup('/invoice/<%= row.VisitID %>', false)">
              <i class="fas fa-file-invoice"></i>
            </a>
            <a href="/invoice/<%= row.VisitID %>?print=1" class="btn btn-ghost btn-sm" title="Print Invoice" onclick="event.stopPropagation(); return openInvoicePopup('/invoice/<%= row.VisitID %>?print=1', true)">
              <i class="fas fa-print"></i>
            </a>
            <% } %>
            <a href="/reports/preview/<%= row.VisitCode %>" target="_blank" class="btn btn-ghost btn-sm" title="Preview" onclick="event.stopPropagation()">
              <i class="fas fa-eye"></i>
            </a>
            <a href="/reports/download/<%= row.VisitCode %>" class="btn btn-ghost btn-sm" title="Download PDF" onclick="event.stopPropagation()">
              <i class="fas fa-download"></i>
            </a>
          </div>
        </div>
        <% }); %>
      </div>

      <% } else { %>
      <div class="card">
        <div style="text-align:center;padding:60px 20px;color:var(--gray-400);">
          <i class="fas fa-search" style="font-size:2.5rem;display:block;margin-bottom:14px;opacity:0.3;"></i>
          <div style="font-size:0.95rem;font-weight:600;color:var(--gray-500);margin-bottom:8px;">No results yet</div>
          <div class="text-sm">Use the search bar or date filter above to find patients.</div>
        </div>
      </div>
      <% } %>

    </main>
  </div>
</div>

<script src="/js/main.js"></script>
<script>
  // ── Date pickers ──
  initDatePicker('fromDate');
  initDatePicker('toDate');

  // ── Filter ──
  function applyFilter() {
    var from = document.getElementById('fromDate').value;
    var to   = document.getElementById('toDate').value;
    if (!from || !to) { showToast('Please select both From and To dates', 'warning'); return; }
    window.location.href = '/Search?FromDate=' + encodeURIComponent(from) + '&ToDate=' + encodeURIComponent(to);
  }

  function clearFilter() {
    window._dpClear('fromDate');
    window._dpClear('toDate');
    window.location.href = '/Search';
  }

  // ── Live filter ──
  function liveFilter(q) {
    q = q.toLowerCase();
    document.querySelectorAll('.result-card').forEach(function(card) {
      var matches = card.dataset.name.includes(q) || card.dataset.code.includes(q) || card.dataset.phone.includes(q);
      card.style.display = matches ? '' : 'none';
    });
  }

  // ── Sort results ──
  function sortResults(by) {
    var grid = document.getElementById('resultsGrid');
    if (!grid) return;
    var cards = Array.from(grid.querySelectorAll('.result-card'));
    cards.sort(function(a, b) {
      if (by === 'name') return a.dataset.name.localeCompare(b.dataset.name);
      if (by === 'code') return a.dataset.code.localeCompare(b.dataset.code);
      return 0;
    });
    cards.forEach(function(c) { grid.appendChild(c); });
  }

  // Auto-focus search
  var ls = document.getElementById('liveSearch');
  if (ls) ls.focus();
</script>
</body>
</html>
